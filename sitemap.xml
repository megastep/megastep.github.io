---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign docs = site.pages | concat: site.posts | sort: "url" %}
{% for doc in docs %}
  {% if doc.url %}
    {% assign skip_doc = false %}
    {% if doc.sitemap == false %}
      {% assign skip_doc = true %}
    {% endif %}
    {% if doc.url contains ".xml" or doc.url contains ".json" %}
      {% assign skip_doc = true %}
    {% endif %}
    {% if doc.url contains ".txt"
      or doc.url contains ".css"
      or doc.url contains ".js"
      or doc.url contains ".png"
      or doc.url contains ".jpg"
      or doc.url contains ".jpeg"
      or doc.url contains ".gif"
      or doc.url contains ".svg"
      or doc.url contains ".ico"
      or doc.url contains ".pdf"
      or doc.url contains ".webmanifest"
      or doc.url contains ".php"
      or doc.url contains ".webp" %}
      {% assign skip_doc = true %}
    {% endif %}
    {% if doc.url contains "/assets/" %}
      {% assign skip_doc = true %}
    {% endif %}
    {% unless skip_doc %}
      {% assign lastmod = doc.last_modified | default: doc.date | default: site.time %}
      {% assign changefreq = "monthly" %}
      {% assign priority = "0.6" %}
      {% if doc.url == "/" %}
        {% assign priority = "1.0" %}
      {% elsif doc.url == "/SDL/" %}
        {% assign changefreq = "yearly" %}
        {% assign priority = "0.8" %}
      {% elsif doc.url contains "/SDL/" %}
        {% assign changefreq = "yearly" %}
        {% assign priority = "0.7" %}
      {% endif %}
  <url>
    <loc>{{ doc.url | absolute_url }}</loc>
    <lastmod>{{ lastmod | date_to_xmlschema }}</lastmod>
    <changefreq>{{ changefreq }}</changefreq>
    <priority>{{ priority }}</priority>
  </url>
    {% endunless %}
  {% endif %}
{% endfor %}
</urlset>
